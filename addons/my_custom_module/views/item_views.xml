<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_custom_item_list" model="ir.ui.view">
        <field name="name">custom.item.list</field>
        <field name="model">custom.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="price"/>
                <field name="qty"/>
            </list>
        </field>
    </record>

    <record id="view_custom_item_form" model="ir.ui.view">
        <field name="name">custom.item.form</field>
        <field name="model">custom.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="price"/>
                        <field name="qty"/>
                    </group>
                </sheet>
                <notebook>
                    <page string="Transaction History">
                        <field name="transaction_ids" readonly="1">
                            <list>
                                <field name="transaction_date"/>
                                <field name="order_id"/>
                                <field name="qty_taken"/>
                                <field name="balance_qty"/>
                            </list>

                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <record id="action_custom_item" model="ir.actions.act_window">
        <field name="name">Items</field>
        <field name="res_model">custom.item</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem 
        id="menu_custom_item"
        name="Items"
        parent="menu_custom_root"
        action="action_custom_item"
        sequence="99"
    />
</odoo>