<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_invoice_list" model="ir.ui.view">
        <field name="name">custom.invoice.list</field>
        <field name="model">custom.invoice</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_name"/>
                <field name="invoice_date"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_form" model="ir.ui.view">
        <field name="name">custom.invoice.form</field>
        <field name="model">custom.invoice</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="order_id"/>
                        <field name="customer_name"/>
                        <field name="invoice_date"/>
                        <field name="amount"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">custom.invoice</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': 0}</field>
    </record>

    <menuitem
        id="menu_invoice"
        name="Invoices"
        parent="menu_custom_root"
        action="action_invoice"
        sequence="5"
    />

</odoo>