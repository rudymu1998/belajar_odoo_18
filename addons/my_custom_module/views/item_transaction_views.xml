<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_item_transaction_list" model="ir.ui.view">
        <field name="name">custom.item.transaction.list</field>
        <field name="model">custom.item.transaction</field>
        <field name="arch" type="xml">
            <list>
                <field name="transaction_date"/>
                <field name="item_id"/>
                <field name="order_id"/>
                <field name="qty_taken"/>
                <field name="balance_qty"/>
            </list>
        </field>
    </record>

    <record id="action_item_transaction" model="ir.actions.act_window">
        <field name="name">Item Transactions</field>
        <field name="res_model">custom.item.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': 0}</field>
    </record>

    <menuitem
        id="menu_item_transaction"
        name="Item Transactions"
        parent="menu_custom_root"
        action="action_item_transaction"
        sequence="3"
    />

</odoo>