<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_custom_order_tree" model="ir.ui.view">
        <field name="name">custom.order.tree</field>
        <field name="model">custom.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_name"/>
                <field name="order_date"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_custom_order_form" model="ir.ui.view">
        <field name="name">custom.order.form</field>
        <field name="model">custom.order</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="customer_name"/>
                        <field name="order_date"/>
                        <field name="amount"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_custom_order" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">custom.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Root Menu -->
    <menuitem id="menu_custom_root"
              name="My Custom Module"
              sequence="10"/>

    <!-- Child Menu -->
    <menuitem id="menu_custom_order"
              name="Orders"
              parent="menu_custom_root"
              action="action_custom_order"
              sequence="1"/>

</odoo>